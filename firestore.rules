rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public read — queue board (board.html) and self-service kiosk (self-service.html)
    // must work without any login. Writes always require authentication.
    match /doctors/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /visits/{id} {
      allow read: if true;
      allow create: if true;           // self-service kiosk creates visits without login
      allow update, delete: if request.auth != null;
    }
    match /clinicSettings/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /counters/{id} {
      allow read: if true;
      allow write: if true;            // token counter transaction must work from self-service kiosk
    }

    // Staff-only — require login for all operations
    match /patients/{id} {
      allow read, write: if request.auth != null;
    }
    match /users/{id} {
      allow read, write: if request.auth != null;
    }
    match /backups/{id} {
      allow read, write: if request.auth != null;
    }

    // Inventory module — staff-only
    match /inventory/{id} {
      allow read, write: if request.auth != null;
    }
    match /stockMovements/{id} {
      allow read, write: if request.auth != null;
    }
    match /purchaseOrders/{id} {
      allow read, write: if request.auth != null;
    }
    match /staffRequests/{id} {
      allow read, write: if request.auth != null;
    }

    // Inpatient module — staff-only
    match /bedCategories/{id} {
      allow read, write: if request.auth != null;
    }
    match /beds/{id} {
      allow read, write: if request.auth != null;
    }
    match /inpatientEncounters/{id} {
      allow read, write: if request.auth != null;
    }
    match /encounterVisits/{id} {
      allow read, write: if request.auth != null;
    }
    match /encounterMedRequests/{id} {
      allow read, write: if request.auth != null;
    }
    match /encounterVitals/{id} {
      allow read, write: if request.auth != null;
    }
    match /encounterCharges/{id} {
      allow read, write: if request.auth != null;
    }
  }
}
